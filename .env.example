# Copy this file to .env and fill in real values for local development.
# .env is gitignored — never commit real secrets.

# HTTP port the api binary listens on (cmd/api).
PORT=8080

# Runtime environment: "development" enables dev-only routes (e.g. POST /dev/reset).
# Use "production" anywhere real.
ENV=development

# Postgres connection string (database/sql + lib/pq).
# Local setup uses a dedicated role + database, both named "lockedin":
#   sudo -u postgres psql \
#     -c "CREATE ROLE lockedin WITH LOGIN PASSWORD '<your-password>';" \
#     -c "CREATE DATABASE lockedin OWNER lockedin;"
# Generate a password with: openssl rand -hex 24
# Keep sslmode=disable for a local non-TLS Postgres.
DB_URL=postgres://lockedin:<your-password>@localhost:5432/lockedin?sslmode=disable
